{
  "name": "node-runtime",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/node/src",
  "tags": ["npm:public"],
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "packages/node/dist",
        "main": "packages/node/src/index.ts",
        "tsConfig": "packages/node/tsconfig.build.json",
        "format": ["esm"],
        "bundle": true,
        "external": [
          "@softarc/native-federation/*",
          "@softarc/native-federation-runtime"
        ]
      },
      "dependsOn": ["^build"],
      "cache": true,
      "inputs": ["production", "^production"]
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/node",
        "command": "vitest run"
      },
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/node",
        "command": "tsc --build --emitDeclarationOnly"
      },
      "cache": true,
      "inputs": [
        "production",
        "^production",
        {
          "externalDependencies": ["typescript"]
        }
      ],
      "dependsOn": ["^build"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint packages/node/src"
      },
      "cache": true,
      "inputs": [
        "default",
        "{workspaceRoot}/eslint.config.mts",
        {
          "externalDependencies": ["eslint"]
        }
      ]
    },
    "nx-release-publish": {
      "executor": "@nx/js:release-publish",
      "dependsOn": ["^nx-release-publish"],
      "options": {}
    }
  },
  "implicitDependencies": ["core", "runtime"]
}
